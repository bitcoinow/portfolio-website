rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Contacts: Anyone can create a new contact message. 
    // Only authenticated admins can read or delete them.
    match /contacts/{document=**} {
      allow create: if true;
      allow read, delete, update: if request.auth != null;
    }

    // Projects: Anyone can read projects to display on the portfolio.
    // Only authenticated admins can create, update, or delete them.
    match /projects/{document=**} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
